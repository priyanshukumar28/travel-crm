generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  AGENT
  INSURER
  SUPER_ADMIN
}

// Point 3: NON_MEDICAL kept in the enum only so we never need a destructive
// migration on old rows — it is no longer offered anywhere in the UI.
// Travel now absorbs those cover names, plus "Assistance".
enum ClaimCategory {
  MEDICAL
  NON_MEDICAL
  TRAVEL
  PERSONAL_ACCIDENT
}

enum ClaimStage {
  INTIMATION
  REGISTRATION
  ASSESSMENT
  PAYMENT
  CLOSED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED_FOR_VALIDATION
  DEFICIENT
  VALIDATED
  INTIMATED_WITH_INSURER
  SUBMITTED_TO_INSURER
  RETURNED_BY_INSURER
  APPROVED
  REJECTED
  PAYMENT_PROCESSED
  CLOSED
}

enum CreatorRole {
  CUSTOMER
  AGENT
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum PolicyCompletionStatus {
  DRAFT
  ACTIVE
}

enum FeedEventStatus {
  APPLIED
  VALIDATION_ERROR
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  phone        String?
  createdAt    DateTime  @default(now())

  policies      Policy[]       @relation("PolicyOwner")
  createdClaims Claim[]        @relation("ClaimCreatedBy")
  activityLogs  ActivityLog[]
  documents     Document[]
}

model ApiKey {
  id        String   @id @default(cuid())
  label     String
  key       String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  events    InsurerFeedEvent[]
}

model InsurerFeedEvent {
  id            String          @id @default(cuid())
  apiKeyId      String?
  apiKey        ApiKey?         @relation(fields: [apiKeyId], references: [id])
  policyNumber  String?
  payload       Json
  status        FeedEventStatus
  errors        Json?
  appliedFields String[]
  createdAt     DateTime        @default(now())
}

model PlanTemplate {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  isActive    Boolean        @default(true)
  coverages   PlanCoverage[]
  policies    Policy[]
  createdAt   DateTime       @default(now())
}

model PlanCoverage {
  id             String        @id @default(cuid())
  planTemplateId String
  planTemplate   PlanTemplate  @relation(fields: [planTemplateId], references: [id], onDelete: Cascade)
  category       ClaimCategory
  coverageName   String
  subCoverName   String?
  sumInsured     Float
  subLimitText   String?
  deductible     String?
}

model DocumentRequirement {
  id                String   @id @default(cuid())
  coverageName      String   @unique
  requiredDocuments String[]
  updatedAt         DateTime @updatedAt
}

model Policy {
  id                 String                  @id @default(cuid())
  policyNumber       String                  @unique
  holderName         String
  planName           String
  claimCategory      ClaimCategory           @default(TRAVEL)
  startDate          DateTime
  endDate            DateTime
  issuanceDate       DateTime
  issuancePlace      String?
  geoCoverage        String
  issuanceBranch     String?
  countryVisited     String?
  countryOfResidence String?
  deductible         String?
  nomineeName        String?
  ownerId            String?
  owner              User?                   @relation("PolicyOwner", fields: [ownerId], references: [id])
  isActive           Boolean                 @default(true)
  completionStatus   PolicyCompletionStatus  @default(ACTIVE)

  planTemplateId String?
  planTemplate   PlanTemplate? @relation(fields: [planTemplateId], references: [id])

  coverages Coverage[]
  members   InsuredMember[]
  claims    Claim[]
  createdAt DateTime @default(now())
}

model Coverage {
  id           String        @id @default(cuid())
  policyId     String
  policy       Policy        @relation(fields: [policyId], references: [id], onDelete: Cascade)
  category     ClaimCategory @default(TRAVEL)
  name         String
  subCoverName String?
  sumInsured   Float
  subLimitText String?
  deductible   String?
}

model InsuredMember {
  id             String    @id @default(cuid())
  policyId       String
  policy         Policy    @relation(fields: [policyId], references: [id], onDelete: Cascade)
  name           String
  dob            DateTime?
  passportNumber String?
  relationship   String?
  createdAt      DateTime  @default(now())
}

model Claim {
  id                String      @id @default(cuid())
  claimNumber       String      @unique
  parentClaimNumber String      // Point 2: multiple claims from one initiation share this
  policyId          String
  policy            Policy      @relation(fields: [policyId], references: [id])

  claimCategory ClaimCategory
  coverages     String[]
  memberIds     String[]

  stage  ClaimStage  @default(INTIMATION)
  status ClaimStatus @default(DRAFT)

  createdById   String
  createdBy     User        @relation("ClaimCreatedBy", fields: [createdById], references: [id])
  createdByRole CreatorRole

  insurerClaimIntimationNo   String?
  insurerClaimRegistrationNo String?

  // Point 4/5/7: each item now also carries currency + computed USD/INR +
  // the exchange rate actually used (pinned to Date of Loss).
  coverageItems Json @default("[]")

  intimationData   Json @default("{}")
  registrationData Json @default("{}")
  assessmentData   Json @default("{}")
  paymentData      Json @default("{}")

  deficiencyReason String?

  // Point 12/14/15: TAT/escalation + queue bucketing state.
  deficiencyReminderCount Int       @default(0)
  lastReminderAt          DateTime?
  deficiencyRaisedAt      DateTime?

  activityLogs  ActivityLog[]
  documents     Document[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      UserRole
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model Document {
  id             String     @id @default(cuid())
  claimId        String
  claim          Claim      @relation(fields: [claimId], references: [id], onDelete: Cascade)
  uploadedById   String
  uploadedBy     User       @relation(fields: [uploadedById], references: [id])
  uploadedByRole UserRole
  stage          ClaimStage
  docType        String
  fileName       String
  url            String
  publicId       String
  mimeType       String
  sizeBytes      Int
  createdAt      DateTime   @default(now())
  // Point 22: no delete field/relation removed here on purpose — documents
  // are permanent once uploaded; re-uploading the same docType is allowed
  // and simply adds another row.
}

model Notification {
  id        String              @id @default(cuid())
  claimId   String
  claim     Claim               @relation(fields: [claimId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  toAddress String
  subject   String?
  message   String
  status    NotificationStatus  @default(QUEUED)
  createdAt DateTime            @default(now())
}
