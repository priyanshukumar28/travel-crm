// Across Assist — Travel Claims Management System
// Prisma schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  AGENT
  INSURER
  SUPER_ADMIN
}

// Point 2: the four claim categories a claim (or an individual coverage
// line within a claim) can belong to.
enum ClaimCategory {
  MEDICAL
  NON_MEDICAL
  TRAVEL
  PERSONAL_ACCIDENT
}

// High-level lifecycle stage — mirrors the BRD flowchart.
// Registration only ever happens in the Agent portal.
// Assessment only ever happens in the Insurer portal.
enum ClaimStage {
  INTIMATION
  REGISTRATION
  ASSESSMENT
  PAYMENT
  CLOSED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED_FOR_VALIDATION
  DEFICIENT
  VALIDATED
  INTIMATED_WITH_INSURER
  SUBMITTED_TO_INSURER
  RETURNED_BY_INSURER
  APPROVED
  REJECTED
  PAYMENT_PROCESSED
  CLOSED
}

enum CreatorRole {
  CUSTOMER
  AGENT
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

// Point 13 continued — a policy that has only received partial data from
// the insurer's feed so far (e.g. Policy Number + dates, but no Sum Insured
// yet) stays DRAFT and is hidden from Customer/Agent portals until every
// core field required to actually service a claim has arrived and it
// flips to ACTIVE.
enum PolicyCompletionStatus {
  DRAFT
  ACTIVE
}

enum FeedEventStatus {
  APPLIED
  VALIDATION_ERROR
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  phone        String?
  createdAt    DateTime  @default(now())

  policies       Policy[]       @relation("PolicyOwner")
  createdClaims  Claim[]        @relation("ClaimCreatedBy")
  activityLogs   ActivityLog[]
  documents      Document[]
}

// ---------- Point 5: reusable plan catalog ----------
// A PlanTemplate is what the insurer actually sells (e.g. "Bronze 25",
// "Platinum 1000" — seeded straight from travel_crm_Sub_Limits.xlsx).
// Every policy is issued *against* a plan template, and the policy's own
// Coverage rows are a materialized copy of the template's PlanCoverage rows
// at the time the policy was issued — so later edits to a plan template
// never silently change an already-issued policy's limits.
// ---------- Point 13: insurer feed authentication + audit trail ----------
// A real insurer integration authenticates with an API key (not a user
// login) and can call the feed endpoint many times for the same policy as
// more fields become available. ApiKey is what the insurer's system
// presents; InsurerFeedEvent is a permanent, append-only record of every
// call received — whether it was applied or rejected on validation — so
// the Admin portal always shows the true history of what the insurer sent
// and when, not just the outcome of the most recent call.
model ApiKey {
  id        String    @id @default(cuid())
  label     String
  key       String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  events    InsurerFeedEvent[]
}

model InsurerFeedEvent {
  id           String           @id @default(cuid())
  apiKeyId     String?
  apiKey       ApiKey?          @relation(fields: [apiKeyId], references: [id])
  policyNumber String?
  payload      Json
  status       FeedEventStatus
  errors       Json?
  appliedFields String[]        // which fields from the payload were actually written, for audit clarity
  createdAt    DateTime         @default(now())
}

model PlanTemplate {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "Bronze 25", "Platinum 1000"
  description String?
  isActive    Boolean  @default(true)
  coverages   PlanCoverage[]
  policies    Policy[]
  createdAt   DateTime @default(now())
}

model PlanCoverage {
  id               String        @id @default(cuid())
  planTemplateId   String
  planTemplate     PlanTemplate  @relation(fields: [planTemplateId], references: [id], onDelete: Cascade)
  category         ClaimCategory
  coverageName     String
  subCoverName     String?       // only meaningful for MEDICAL category
  sumInsured       Float
  subLimitText     String?       // free-text sub-limit description (matches the excel's "USD 1500 Per Day up to 30 Days" style values)
  deductible       String?
}

// ---------- Point 1: dynamic, admin-configurable document requirements ----------
// Seeded straight from the BRD's coverage/document checklist (36 coverages).
// Admin can add/edit/remove required documents per coverage name without
// touching code — every claim workspace's Documents tab reads this list
// live based on the coverages actually selected on that claim.
model DocumentRequirement {
  id                String   @id @default(cuid())
  coverageName      String   @unique
  requiredDocuments String[]
  updatedAt         DateTime @updatedAt
}

model Policy {
  id             String        @id @default(cuid())
  policyNumber   String        @unique
  holderName     String
  planName       String
  claimCategory  ClaimCategory @default(TRAVEL)
  startDate      DateTime
  endDate        DateTime
  issuanceDate   DateTime
  issuancePlace  String?
  geoCoverage    String
  issuanceBranch String?
  countryVisited String?
  countryOfResidence String?
  deductible     String?
  nomineeName    String?
  ownerId        String?
  owner          User?         @relation("PolicyOwner", fields: [ownerId], references: [id])
  isActive       Boolean       @default(true)
  completionStatus PolicyCompletionStatus @default(ACTIVE)

  planTemplateId String?
  planTemplate   PlanTemplate? @relation(fields: [planTemplateId], references: [id])

  coverages      Coverage[]
  members        InsuredMember[]
  claims         Claim[]
  createdAt      DateTime      @default(now())
}

model Coverage {
  id           String        @id @default(cuid())
  policyId     String
  policy       Policy        @relation(fields: [policyId], references: [id], onDelete: Cascade)
  category     ClaimCategory @default(TRAVEL)
  name         String
  subCoverName String?
  sumInsured   Float
  subLimitText String?
  deductible   String?
}

// ---------- Point 12: real insured members, scoped to a policy ----------
// A claim can only ever be raised for member(s) who actually exist on the
// policy — the claim initiation screen reads this list to populate the
// member picker instead of a free-text field.
model InsuredMember {
  id             String   @id @default(cuid())
  policyId       String
  policy         Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  name           String
  dob            DateTime?
  passportNumber String?
  relationship   String?  // Self, Spouse, Child, Parent, etc.
  createdAt      DateTime @default(now())
}

model Claim {
  id                     String      @id @default(cuid())
  claimNumber            String      @unique
  parentClaimNumber      String
  policyId               String
  policy                 Policy      @relation(fields: [policyId], references: [id])

  // Point 2: the primary category picked at Initiate Claim. Individual
  // coverage line items (below) each carry their own category too, since a
  // single claim can legitimately mix e.g. Medical + Non-Medical coverages
  // (point 4/8/9) even though it's filed under one primary category.
  claimCategory          ClaimCategory

  coverages              String[]    // display-only summary of coverage names, kept for quick listing
  memberIds              String[]    // InsuredMember ids this claim was raised for (point 12)

  stage                  ClaimStage  @default(INTIMATION)
  status                 ClaimStatus @default(DRAFT)

  createdById            String
  createdBy              User        @relation("ClaimCreatedBy", fields: [createdById], references: [id])
  createdByRole          CreatorRole

  // Structured core fields used for search / listing
  insurerClaimIntimationNo   String?
  insurerClaimRegistrationNo String?

  // Point 4/7/8/9: one row per selected coverage — category, cover name,
  // sub-cover name (medical only), initial reserve (renamed from "estimated
  // loss"), sub-limit, running total and GOP issue date all live per-item
  // here rather than as flat claim-level fields, because every coverage on
  // a multi-coverage claim needs its own values. Stored as JSON (an array
  // of objects) for the same reason the stage payloads below are JSON —
  // the shape can evolve without a migration.
  coverageItems  Json  @default("[]")

  // Flexible stage payloads — each stores every wireframe field for that
  // stage as JSON, keyed by field id. Keeping these as JSONB lets the form
  // schema evolve (new insurer fields, new coverages) without a migration
  // for every field, while the columns above stay indexable for search.
  intimationData   Json  @default("{}")
  registrationData Json  @default("{}")
  assessmentData   Json  @default("{}")
  paymentData      Json  @default("{}")

  deficiencyReason String?

  activityLogs ActivityLog[]
  documents     Document[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Point 11: every activity log row already carries who (userId/role) and
// when (createdAt). "action" doubles as a free-text remark when an agent
// explicitly adds one via POST /claims/:id/remarks — so the same table
// serves both the automatic system trail and manual remarks, all in one
// chronological, attributable feed.
model ActivityLog {
  id        String   @id @default(cuid())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      UserRole
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model Document {
  id             String   @id @default(cuid())
  claimId        String
  claim          Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  uploadedById   String
  uploadedBy     User     @relation(fields: [uploadedById], references: [id])
  uploadedByRole UserRole
  stage          ClaimStage
  docType        String
  fileName       String   // original filename shown to users
  url            String   // Cloudinary secure_url — no local disk involved
  publicId       String   // Cloudinary public_id, needed to delete the file later
  mimeType       String
  sizeBytes      Int
  createdAt      DateTime @default(now())
}

model Notification {
  id        String               @id @default(cuid())
  claimId   String
  claim     Claim                @relation(fields: [claimId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  toAddress String
  subject   String?
  message   String
  status    NotificationStatus   @default(QUEUED)
  createdAt DateTime             @default(now())
}
